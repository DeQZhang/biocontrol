# Docker Compose mode
BIOCONTROL_FRONTEND_CONTAINER_NAME=biocontrol-frontend
BIOCONTROL_FRONTEND_IMAGE_NAME=biocontrol-frontend:latest
BIOCONTROL_BACKEND_CONTAINER_NAME=biocontrol-backend
BIOCONTROL_BACKEND_IMAGE_NAME=biocontrol-backend:latest
BIOCONTROL_MYSQL_CONTAINER_NAME=biocontrol-mysql

BIOCONTROL_FRONTEND_PUBLISHED_PORT=8080

BIOCONTROL_DB_HOST=mysql
BIOCONTROL_DB_PORT=3306
BIOCONTROL_DB_NAME=biocontrol
BIOCONTROL_DB_USER=biocontrol
BIOCONTROL_DB_PASSWORD=AUTO_GENERATED
BIOCONTROL_DB_CHARSET=utf8mb4
BIOCONTROL_DB_COLLATION=utf8mb4_unicode_ci
BIOCONTROL_DB_MAX_RETRIES=30
BIOCONTROL_DB_RETRY_DELAY_SECONDS=2
BIOCONTROL_MYSQL_ROOT_PASSWORD=AUTO_GENERATED
BIOCONTROL_MYSQL_VOLUME_NAME=biocontrol-mysql-data

BIOCONTROL_HTTP_ADDR=0.0.0.0
BIOCONTROL_HTTP_PORT=8080
BIOCONTROL_TZ=Asia/Shanghai
BIOCONTROL_LOG_MAX_SIZE=10m
BIOCONTROL_LOG_MAX_FILE=3
